# E2E configuration — copy to  e2e/.env  and fill in the values.
#
# Loaded ONLY by the e2e suite (e2e/support/env.ts). It is intentionally
# separate from the repo-root .env (real service config) and must never be
# merged into it. .env is gitignored, so the filled-in e2e/.env is never
# committed.
#
# Naming convention: every variable here that exists ONLY for the e2e suite is
# prefixed `E2E_` (and `E2E_GROUP_` for the per-test-group accounts), so it can
# never be confused with a real service deployment variable. The one exception
# is CGS_ADMIN_PASSWORD, which is a real service-deployment credential (set on
# the CGS instance under test), not an e2e-only var — so it keeps its real name.
#
# The suite tests CGS functionality, not PDS-account creation: every account
# below is PRE-PROVISIONED up front. The suite never creates PDS accounts.
#
# In the common case the importer and owner are the SAME account — copy the
# same values into both blocks.

# --- CGS under test (the only var the @health feature needs) ---
E2E_CGS_URL=https://certified-group-service-...up.railway.app

# Service-level aud (import/register). Defaults to did:web:<E2E_CGS_URL host>.
# Override only if the deployment's SERVICE_URL points elsewhere.
# E2E_CGS_SERVICE_DID=did:web:...

# --- Importer: the pre-provisioned account promoted to a group (= groupDid) ---
# Signs the import JWT (iss === groupDid). Identifier may be a handle or a DID.
E2E_GROUP_IMPORTER_IDENTIFIER=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx
# The importer's full account password (used by the import fixture and the
# app-password helper). Required for everything except @health.
E2E_GROUP_IMPORTER_PASSWORD=
# An app password for the importer, stored by import so the service can act on
# its behalf. Mint one with:  pnpm e2e:app-password
E2E_GROUP_IMPORTER_APP_PASSWORD=
# Optional label for the app password the helper mints on the importer account.
# E2E_GROUP_IMPORTER_APP_PASSWORD_NAME=cgs-e2e-smoke

# --- Group owner: the DID seeded as the RBAC owner (commonly == importer) ---
E2E_GROUP_OWNER_IDENTIFIER=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx
# The owner's full account password (signs owner-gated calls).
E2E_GROUP_OWNER_PASSWORD=

# --- RBAC accounts (for the @needs-rbac-accounts membership feature) ---
# Distinct pre-provisioned accounts WITH passwords, so each can sign its own
# service-auth JWTs and we can test both allowed and denied operations. The
# membership feature is skipped unless all six are set.
E2E_GROUP_ADMIN_IDENTIFIER=
E2E_GROUP_ADMIN_PASSWORD=
E2E_GROUP_MEMBER_IDENTIFIER=
E2E_GROUP_MEMBER_PASSWORD=
# An account that is NOT a member, for negative authorization tests.
E2E_GROUP_OUTSIDER_IDENTIFIER=
E2E_GROUP_OUTSIDER_PASSWORD=

# --- CGS service admin password (for the @needs-cgs-admin admin-set-owner feature) ---
# The HTTP Basic password for the operator-only app.certified.group.admin.*
# endpoints. This is the SAME value set as CGS_ADMIN_PASSWORD on the CGS
# deployment under test — a real service credential, not an e2e-only var, so it
# is NOT E2E_-prefixed. The admin-set-owner feature is skipped unless this and
# the RBAC accounts are all set.
CGS_ADMIN_PASSWORD=
