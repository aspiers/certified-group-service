# Smoke-test config for the app.certified.group import/destroy flows.
#
# Copy this file to  tests/smoke/.env  and fill in the values.
# This file is loaded ONLY by the tests/smoke/*.ts scripts — it is intentionally
# separate from the repo-root .env (real service config) and must never be merged
# into it. .env is gitignored, so the filled-in tests/smoke/.env is never committed.
#
# There are two accounts here. In the common case they are the SAME account, in
# which case copy the same values into both blocks (IMPORTER_* and GROUP_OWNER_*).
#   - The IMPORTER is the account being promoted to a group (groupDid). It signs
#     the import JWT (import auth is option a: iss === groupDid) and an app
#     password is minted on it.
#   - The GROUP OWNER is the DID seeded as the group's RBAC owner (groupOwnerIdentifier).
#     It signs the owner-gated destroy JWT.

# --- CGS under test ---
# The PR-30 Railway preview (already deployed):
CGS_URL=https://certified-group-service-certified-group-service-pr-30.up.railway.app

# The JWT `aud` for service-level calls (import) must equal the CGS's configured
# serviceDid. By default the script derives it as did:web:<CGS_URL host>. Set this
# ONLY if the preview's SERVICE_URL points somewhere other than its own preview
# URL (e.g. inherited from `test`), in which case use did:web:<that host>.
# (destroy is group-scoped — its aud is the group DID, not the service DID.)
# CGS_SERVICE_DID=did:web:certified-group-service-certified-group-service-pr-30.up.railway.app

# --- Importer: the account being promoted to a group (groupDid) ---
# Signs the import JWT, so it must be able to mint a service-auth JWT proving
# control of its DID. The scripts obtain that via a password login (a smoke-test
# convenience — real callers use OAuth/getServiceAuth), so IMPORTER_PASSWORD must
# be a real account password. ePDS accounts are OTP/OAuth-first, so set a password
# on the throwaway test account if it doesn't have one.
IMPORTER_PDS=https://pds.example.com
# A handle or a DID — destroy resolves a handle to a DID, and login accepts either.
IMPORTER_IDENTIFIER=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx
IMPORTER_PASSWORD=
# App password for the importer account, so the service can act on its behalf.
# Mint one with: npx tsx tests/smoke/create-app-password.ts
IMPORTER_APP_PASSWORD=

# --- Group owner: the DID seeded as the group's owner (groupOwnerDid) ---
# Common case: this IS the importer account — copy the IMPORTER_* values here.
# Used as the ownerDid in import, and to sign the owner-gated destroy JWT
# (destroy requires the caller to hold the owner role).
GROUP_OWNER_PDS=https://pds.example.com
# A handle or a DID — import resolves a handle to a DID for the seeded ownerDid.
GROUP_OWNER_IDENTIFIER=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx
GROUP_OWNER_PASSWORD=
